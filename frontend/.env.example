# Quality Copilot — Frontend environment variables
# Copy to .env for local overrides. Never commit .env.

APP_TITLE=Quality Copilot
BACKEND_URL=http://127.0.0.1:8000
API_V1_PREFIX=/api/v1
HOST=127.0.0.1
PORT=9000
RELOAD=true

# Required for login sessions. Generate a unique value for any shared deploy.
STORAGE_SECRET=
