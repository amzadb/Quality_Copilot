# Quality Copilot — Backend environment variables
# Copy to .env and adjust as needed.

APP_NAME=Quality Copilot
API_V1_PREFIX=/api/v1
DEBUG=false

# SQLite (default for local development)
DATABASE_URL=sqlite:///./quality_copilot.db

# Integration credentials file (legacy shared fallback when unauthenticated)
CREDENTIALS_PATH=./data/credentials.json

# Auth — change JWT_SECRET in any shared/production environment
JWT_SECRET=dev-only-change-me-quality-copilot
JWT_EXPIRE_MINUTES=1440
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# JIRA Cloud API token auth uses email + token (email is server-side only)
JIRA_EMAIL=you@example.com

# Anthropic / Claude defaults for LLM integration
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_API_VERSION=2023-06-01

# PostgreSQL example (production)
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/quality_copilot
