# Quality Copilot — Backend environment variables
# Copy to .env and adjust as needed. Never commit .env.

APP_NAME=Quality Copilot
API_V1_PREFIX=/api/v1
DEBUG=false

# SQLite (default for local development)
DATABASE_URL=sqlite:///./quality_copilot.db

# Integration credentials file (legacy shared fallback when unauthenticated)
CREDENTIALS_PATH=./data/credentials.json

# Auth — REQUIRED for non-debug startups. Generate a unique value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
JWT_EXPIRE_MINUTES=1440

# Encrypt integration tokens at rest (Fernet). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_ENCRYPTION_KEY=

# Optional admin seed (only if ADMIN_PASSWORD is set). No default password.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Local throwaway only: DEBUG=true allows an ephemeral JWT_SECRET when unset.
# DEBUG=true

# JIRA Cloud API token auth uses email + token (email is server-side only)
JIRA_EMAIL=you@example.com

# Anthropic / Claude defaults for LLM integration
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_API_VERSION=2023-06-01

# PostgreSQL example (production)
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/quality_copilot
